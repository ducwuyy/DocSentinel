# Arthor Agent — Environment template
# Copy to .env and fill in values.

ENV=development
LOG_LEVEL=INFO
API_PREFIX=/api/v1

# Secret for sessions/signing (generate a random string)
SECRET_KEY=change-me-in-production

# Upload limits (PRD / 05-deployment-runbook)
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_MAX_FILES=10
PARSER_TIMEOUT_SECONDS=120

# LLM (choose one provider for MVP)
LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Vector store / Knowledge base
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: AAD (see docs/04-integration-guide.md)
# AAD_TENANT_ID=
# AAD_CLIENT_ID=
# AAD_CLIENT_SECRET=
# AAD_REDIRECT_URI=

# Optional: ServiceNow (see docs/04-integration-guide.md)
# SERVICENOW_INSTANCE=
# SERVICENOW_USERNAME=
# SERVICENOW_PASSWORD=
